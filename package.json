{
  "name": "lapsecam",
  "productName": "LapseCam",
  "version": "1.1.0",
  "description": "Record sped up videos of your study sessions with no editing.",
  "author": "Ali Rad",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/gen-icon.js",
    "dist": "npm run icon && electron-builder --win portable nsis && node scripts/set-exe-icon.js",
    "pack": "npm run icon && electron-builder --dir && node scripts/set-exe-icon.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.lapsecam.app",
    "productName": "LapseCam",
    "files": [
      "src/**/*",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "executableName": "LapseCam",
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "portable": {
      "artifactName": "LapseCam-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "LapseCam-${version}-setup.exe"
    }
  }
}
